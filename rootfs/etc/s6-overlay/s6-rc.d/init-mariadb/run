#!/usr/bin/with-contenv bashio

DB_NAME=$(bashio::config 'db_name')
DB_USER=$(bashio::config 'db_user')
DB_PASS=$(bashio::config 'db_password')

if [ ! -d "/data/mysql/mysql" ]; then
  bashio::log.info "Initializing MariaDB database..."
  mariadb-install-db --user=mysql --datadir=/data/mysql
fi

bashio::log.info  "Waiting for MariaDB..."

until mysqladmin ping -h "127.0.0.1" --silent; do
  sleep 1
done

bashio::log.info "MariaDB is ready"
bashio::log.info  "Creating database..."



mysql -u root <<EOF
CREATE DATABASE IF NOT EXISTS $DB_NAME;
CREATE USER IF NOT EXISTS '$DB_USER'@'localhost' IDENTIFIED BY '$DB_PASS';
GRANT ALL PRIVILEGES ON $DB_NAME.* TO '$DB_USER'@'localhost';
FLUSH PRIVILEGES;
EOF

bashio::log.info "MariaDB setup completed"